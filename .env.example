# Copia este archivo como .env.local y completa los valores reales.
# Nunca subas .env.local ni ningún archivo .env con valores reales al repositorio.

# URL pública del sitio (usada en metadata, sitemap, OG tags)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — proyecto (development/preview/production tienen valores distintos)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase — solo servidor. NUNCA debe llevar prefijo NEXT_PUBLIC_. NUNCA se expone al navegador.
SUPABASE_SECRET_KEY=

# Supabase — CI / migraciones (solo en GitHub Actions environment "production")
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
SUPABASE_ACCESS_TOKEN=

# Vercel — solo si se usa despliegue por CLI en vez de integración Git nativa
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
VERCEL_TOKEN=
