{
  "name": "herbal-vapor-lab",
  "version": "0.1.0",
  "private": true,
  "description": "Herbal Evidence Lab — biblioteca pública de plantas medicinales, evidencia y seguridad.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "check:content": "tsx scripts/check-content.ts",
    "verify:env": "tsx scripts/verify-env.ts",
    "db:types": "supabase gen types typescript --local > lib/supabase/database.types.ts",
    "ci": "pnpm lint && pnpm format && pnpm typecheck && pnpm test && pnpm check:content && pnpm build"
  },
  "dependencies": {
    "next": "15.1.11",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "@supabase/supabase-js": "^2.48.0",
    "@supabase/ssr": "^0.5.2",
    "zod": "^3.24.1",
    "react-hook-form": "^7.54.2",
    "@hookform/resolvers": "^3.10.0",
    "@tanstack/react-table": "^8.20.6",
    "@tanstack/react-query": "^5.64.1",
    "next-themes": "^0.4.4",
    "lucide-react": "^0.469.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "tailwindcss": "^3.4.17",
    "postcss": "^8.5.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-config-next": "16.2.10",
    "@eslint/eslintrc": "^3.2.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "vitest": "^2.1.8",
    "@vitejs/plugin-react": "^4.3.4",
    "@testing-library/react": "^16.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@vitest/coverage-v8": "^2.1.8",
    "jsdom": "^25.0.1",
    "@playwright/test": "^1.49.1",
    "tsx": "^4.19.2",
    "supabase": "^2.6.8"
  }
}
